{
  "name": "alfred",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:start": "\"${ALFRED_PG_CTL:-/opt/homebrew/opt/postgresql@17/bin/pg_ctl}\" -D \"${ALFRED_PGDATA:-/opt/homebrew/var/postgresql@17}\" -l /tmp/alfred-pg.log start",
    "db:stop": "\"${ALFRED_PG_CTL:-/opt/homebrew/opt/postgresql@17/bin/pg_ctl}\" -D \"${ALFRED_PGDATA:-/opt/homebrew/var/postgresql@17}\" stop",
    "db:migrate": "pnpm --filter @alfred/db db:migrate",
    "predev": "pnpm --filter \"./packages/*\" build",
    "dev": "concurrently -k -n worker,server,web,discord -c green,cyan,magenta,blue \"pnpm --filter @alfred/worker dev\" \"pnpm --filter @alfred/webserver dev\" \"pnpm --filter @alfred/web dev\" \"pnpm --filter @alfred/discord dev\"",
    "dev:up": "pnpm db:start || echo db already running && pnpm db:migrate && pnpm dev",
    "deploy:up": "pm2 start ecosystem.config.cjs --env deploy",
    "deploy:down": "pm2 kill"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.7.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.0"
  }
}
