{
  "manifest_version": 3,
  "name": "Alfred",
  "version": "1.0.0",
  "description": "Lets Alfred browse the web using your real Chrome session",
  "permissions": ["activeTab", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {},
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
