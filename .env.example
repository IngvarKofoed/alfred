# === Webserver ===
WEBSERVER_PORT=3000
# Interface to bind. Default 0.0.0.0 = reachable on the LAN/tailnet (the iOS app + other owner
# devices connect here). Set to 127.0.0.1 to restrict to loopback (e.g. fronted only by
# `tailscale serve`). No auth — network position is the auth (ARCHITECTURE §12), and the LAN
# behind the home firewall is part of that trusted boundary.
WEBSERVER_HOST=0.0.0.0

# === Database ===
# Optional: the webserver boots without it; packages/db requires it when a client opens.
# Local dev (macOS, brew postgresql@17): postgres://<your-user>@localhost:5432/alfred
POSTGRES_URL=postgres://localhost:5432/alfred

# === LLM (Gemini) ===
# Optional: agent-core's GeminiProvider fails fast if it's missing when used (so the
# worker needs it, but the webserver still boots without it). Get a key from
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Default Gemini model used by the agent loop (provider-scoped key).
GEMINI_MODEL=gemini-2.5-flash

# === Voice (STT/TTS) ===
# Hands-free voice for the iOS app (spec 2026-06-14-voice-stt-tts.md). Provider-swappable,
# keys server-side only (ARCHITECTURE §9.3). Defaults reuse the Gemini-native audio path
# via GEMINI_API_KEY above — no extra key needed for the google/google default.
STT_PROVIDER=google              # 'google' | 'elevenlabs' (default google)
TTS_PROVIDER=google              # 'google' | 'elevenlabs' (default google)
# Fallback for Google Cloud Speech-to-Text/Text-to-Speech REST. Optional — only if the
# Gemini-native audio path is unavailable.
GOOGLE_SPEECH_API_KEY=
# Required only if STT_PROVIDER or TTS_PROVIDER=elevenlabs. Higher-quality TTS.
ELEVENLABS_API_KEY=
# Default synthesis voice (provider-specific id/name). Optional — provider default if unset.
TTS_VOICE=

# === Browser bridge (embedded in the worker) ===
# Loopback-only WebSocket port the Chrome extension connects to. Optional (defaults to
# 7865). No auth token or extension ID needed: the bridge binds to 127.0.0.1 and accepts
# only connections whose Origin is chrome-extension:// (ARCHITECTURE §8).
BRIDGE_WS_PORT=7865

# === Python tools (worker: run_python / pip_install) ===
# Interpreter used to create the shared venv. Optional (defaults to python3 on
# macOS/Linux, python on Windows).
PYTHON_BIN=python3
# Where the shared venv lives, created lazily on first use. Optional (defaults here);
# a relative path is anchored at the repo root, like WORKSPACE_ROOT.
PYTHON_VENV_DIR=./data/python-venv

# === Auto-deploy updater (services/updater) ===
# Opt-in. The updater polls git and redeploys only when true (default false).
# `pnpm deploy:up` enables it via pm2 --env deploy without editing this file; or set true here.
DEPLOY_ENABLED=false
# Branch the deploy box tracks.
DEPLOY_BRANCH=main
# Poll interval in ms (default 5 min).
DEPLOY_POLL_INTERVAL_MS=300000
# Comma-separated pm2 app names the updater stops/starts (never itself). Track the long-running set
# in ecosystem.config.cjs so a new ingress is actually redeployed.
DEPLOY_APPS=alfred-webserver,alfred-worker,alfred-triggers,alfred-discord

# === Email tools (worker: list/search/read_email, save_draft, send_email) ===
# Provider-agnostic IMAP (reading) + SMTP (sending). Optional: the worker boots without
# them; an invoke with missing config returns a clear "email not configured" error.
# Gmail/Fastmail/etc. with an app password — no OAuth.
IMAP_HOST=                       # e.g. imap.gmail.com / imap.fastmail.com
IMAP_PORT=993                    # default 993
IMAP_USER=                       # mailbox login
IMAP_PASSWORD=                   # app password
IMAP_SECURE=true                 # TLS on connect (default true); "false" stays false
SMTP_HOST=                       # e.g. smtp.gmail.com / smtp.fastmail.com
SMTP_PORT=465                    # default 465
SMTP_USER=                       # mailbox login
SMTP_PASSWORD=                   # app password
SMTP_SECURE=true                 # TLS on connect (default true); "false" stays false
EMAIL_FROM=                      # From address for outgoing mail; defaults to SMTP_USER

# === Autonomous watchers (alfred-triggers + worker) ===
# spec docs/specs/2026-06-16-autonomous-watchers.md. The tiered detection ladder + Web Push.
# Cheap Tier-1 triage model. Optional — falls back to GEMINI_MODEL when unset.
DETECTION_MODEL=                 # e.g. gemini-2.5-flash-lite
# Approval timeout for unattended (trigger) runs, in ms. Default 24h (vs the 1h interactive one).
AUTONOMOUS_APPROVAL_TIMEOUT_MS=86400000
# Web Push VAPID material. All optional: Web Push is inert if unset (like the email keys).
# Generate a keypair with `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=                # base64url public key (also served to the PWA)
VAPID_PRIVATE_KEY=               # base64url private key (server-side only)
VAPID_SUBJECT=                   # a mailto: or https: contact, required by the Web Push spec

# === Discord bot (alfred-discord) ===
# Second interactive ingress (spec 2026-06-16-discord-bot.md). Both optional: with either
# unset the process logs "discord not configured; idling" and stays alive doing nothing.
# DISCORD_BOT_TOKEN is from the Discord developer portal (Bot → Token); the bot also needs
# the privileged "Message Content Intent" enabled there (Bot → Privileged Gateway Intents)
# or the gateway rejects login. ALLOWED_DISCORD_USER_ID is the owner's Discord user id —
# every message/interaction from anyone else is dropped (being the owner is the auth, §12).
DISCORD_BOT_TOKEN=               # bot token from the Discord developer portal
ALLOWED_DISCORD_USER_ID=         # the owner's Discord user id (owner-only)
# Optional: the id of the private Alfred guild (server). When set, the bot uses the
# forum-thread conversation model (spec 2026-06-17-discord-conversation-model.md) — a forum
# post is a conversation, the DM redirects to the guild, and each watcher is its own post.
# Forums need a Community-enabled guild + the bot's Manage Channels permission. Unset ⇒ the
# DM+mention bot is unchanged.
DISCORD_GUILD_ID=                # the private Alfred guild id (enables the forum model)
